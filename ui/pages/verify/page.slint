import { ContentSection, AppHeader, TextLg, TextMd, TextSm, BasePage,
         PageBody, IconButton, JumboIcon, Icon } from "../../compat/widgets.slint";
import { Importance, Palette, Size, IconSize } from "../../compat/theme.slint";
import { Callbacks } from "../../callbacks.slint";
import { VerifyPageProps } from "./props.slint";
import { Navigate } from "../../gen/navigate.slint";
import { TR2, TrId } from "../../gen/tr.slint";
import { Liana } from "../../liana-theme.slint";
import { LianaCard } from "../../liana-widgets.slint";

export component VerifyPagePage inherits Rectangle {
    in property <VerifyPageProps> props;

    BasePage {
        VerticalLayout {
            AppHeader {
                title: TR2.lookup(TrId.VerifyTitle);
                side-padding: Size.sz6;
                IconButton {
                    icon: "chevron-left";
                    size: Size.sz8;
                    importance: Importance.normal;
                    clicked => { Navigate.backward(); }
                }
                Rectangle { }
            }

            PageBody {
                ContentSection {
                    spacing: Size.sz3;

                    HorizontalLayout {
                        alignment: center;
                        padding-top: Size.sz2;
                        JumboIcon {
                            name: "jumbo-circle";
                            // Liana-green check when verified, red warning when not.
                            Icon {
                                name: Callbacks.verify-matched ? "check" : "alert";
                                size: IconSize.px96;
                                color: Callbacks.verify-matched ? Liana.green : Liana.recovery;
                            }
                        }
                    }

                    TextLg {
                        text: Callbacks.verify-title;
                        color: Callbacks.verify-matched ? Liana.green : Liana.recovery;
                        bold: true;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    TextMd {
                        text: Callbacks.verify-detail;
                        color: Palette.content-secondary;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    if Callbacks.verify-addr != "": LianaCard {
                        width: 448px;
                        height: 96px;
                        recovery: !Callbacks.verify-matched;
                        VerticalLayout {
                            padding: Size.sz4;
                            alignment: center;
                            TextSm { text: TR2.lookup(TrId.VerifyAddressLabel); color: Liana.on-surface-dim; }
                            TextMd { text: Callbacks.verify-addr; color: Liana.on-surface; wrap: word-wrap; }
                        }
                    }
                }
            }
        }
    }
}

import { AppHeader, TextLg, TextMd, TextSm,
         BasePage, ScrollBody, IconButton } from "../../compat/widgets.slint";
import { Importance, Palette, Size } from "../../compat/theme.slint";
import { Callbacks, PolicyRow } from "../../callbacks.slint";
import { ArchivePageProps } from "./props.slint";
import { Navigate } from "../../gen/navigate.slint";
import { TR2, TrId } from "../../gen/tr.slint";
import { Liana } from "../../liana-theme.slint";
import { LianaCard } from "../../liana-widgets.slint";

export component ArchivePagePage inherits Rectangle {
    in property <ArchivePageProps> props;

    BasePage {
        VerticalLayout {
            AppHeader {
                title: TR2.lookup(TrId.ArchiveTitle);
                side-padding: Size.sz6;
                IconButton {
                    icon: "chevron-left";
                    size: Size.sz8;
                    importance: Importance.normal;
                    clicked => { Navigate.backward(); }
                }
                Rectangle { }
            }

            ScrollBody {
                p-x: Size.sz4;
                VerticalLayout {
                    spacing: Size.sz3;

                    if Callbacks.archived-count == 0: TextMd {
                        text: TR2.lookup(TrId.ArchiveEmpty);
                        color: Palette.content-secondary;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    for entry in Callbacks.archived-policies: Rectangle {
                        height: 96px;
                        LianaCard {
                            width: 448px;
                            height: parent.height;
                            change: true;  // muted grey, signalling "set aside"
                            VerticalLayout {
                                padding-left: Size.sz5;
                                padding-right: Size.sz5;
                                alignment: center;
                                spacing: Size.sz0_5;
                                TextLg {
                                    text: entry.name;
                                    color: Liana.on-surface;
                                    bold: true;
                                    overflow: elide;
                                }
                                TextSm { text: entry.summary; color: Liana.on-surface-dim; }
                                TextSm { text: entry.checksum; color: Liana.on-surface-dim; }
                            }
                        }
                        TouchArea {
                            clicked => {
                                Callbacks.select-policy(entry.id);
                                Navigate.policy-page({ });
                            }
                        }
                    }
                }
            }
        }
    }
}

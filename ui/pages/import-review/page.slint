import { ButtonSection, AppHeader, HeadingLg, TextMd, TextSm, BasePage,
         ScrollBody, IconButton, JumboIcon, Icon, TitledInput } from "@ui/widgets.slint";
import { Importance, Palette, Size, IconSize } from "@ui/theme.slint";
import { Callbacks } from "../../callbacks.slint";
import { ImportReviewPageProps } from "./props.slint";
import { Navigate } from "../../gen/navigate.slint";
import { TR2, TrId } from "../../gen/tr.slint";
import { Liana } from "../../liana-theme.slint";
import { LianaButton } from "../../liana-widgets.slint";

export component ImportReviewPagePage inherits Rectangle {
    in property <ImportReviewPageProps> props;

    BasePage {
        VerticalLayout {
            AppHeader {
                title: TR2.lookup(TrId.ImportReviewTitle);
                side-padding: Size.sz6;
                IconButton {
                    icon: "chevron-left";
                    size: Size.sz8;
                    importance: Importance.normal;
                    clicked => {
                        Callbacks.cancel-import();
                        Navigate.backward();
                    }
                }
                Rectangle { }
            }

            ScrollBody {
                p-x: Size.sz4;
                VerticalLayout {
                    spacing: Size.sz4;

                    // Brand mark for a confident, less wall-of-text intro.
                    HorizontalLayout {
                        alignment: center;
                        padding-top: Size.sz2;
                        JumboIcon {
                            name: "jumbo-circle";
                            Icon { name: "liana"; size: IconSize.px96; color: Liana.green; }
                        }
                    }

                    // Wallet identity.
                    HeadingLg { text: TR2.lookup(TrId.ImportReviewNewWallet); horizontal-alignment: center; }
                    HorizontalLayout {
                        alignment: center;
                        spacing: Size.sz2;
                        TextSm { text: Callbacks.detail-network; color: Liana.green; }
                        TextSm { text: Callbacks.detail-checksum; color: Palette.content-tertiary; }
                    }

                    // What's happening.
                    TextMd {
                        text: TR2.lookup(TrId.ImportReviewBody);
                        color: Palette.content-secondary;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    // Give the wallet a name (editable; defaults to "Liana wallet").
                    TitledInput {
                        title: TR2.lookup(TrId.ImportReviewWalletName);
                        placeholder: TR2.lookup(TrId.ImportReviewWalletNamePlaceholder);
                        caps-mode: sentences;
                        text <=> Callbacks.import-name;
                    }
                }
            }

            ButtonSection {
                padding-left: Size.sz6;
                padding-right: Size.sz6;
                padding-bottom: Size.sz6;
                LianaButton {
                    label: TR2.lookup(TrId.CommonButtonContinue);
                    primary: true;
                    clicked => { Navigate.import-paths-page({ }); }
                }
                LianaButton {
                    label: TR2.lookup(TrId.CommonButtonCancel);
                    primary: false;
                    clicked => {
                        Callbacks.cancel-import();
                        Navigate.home-page({ });
                    }
                }
            }
        }
    }
}

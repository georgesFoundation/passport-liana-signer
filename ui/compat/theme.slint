    out property <length> sz0_5: 2px;
    out property <length> sz0_75: 3px;
    out property <length> sz1: 4px;
    out property <length> sz2: 8px;
    out property <length> sz2_5: 10px;
    out property <length> sz3: 12px;
    out property <length> sz4: 16px;
    out property <length> sz5: 20px;
    out property <length> sz6: 24px;
    out property <length> sz7: 28px;
    out property <length> sz8: 32px;
    out property <length> sz9: 36px;
    out property <length> sz10: 40px;
    out property <length> sz11: 44px;
    out property <length> sz12: 48px;
    out property <length> sz13: 52px;
    out property <length> sz14: 56px;
    out property <length> sz15: 60px;
    out property <length> sz16: 64px;
}

export global IconSize {
    out property <length> px16: 16px;
    out property <length> px24: 24px;
    out property <length> px32: 32px;

// Liana-green variant of the shared SlideToButton (same geometry + gesture as
// the Bitcoin app's slide-to-sign; only the thumb/label colors are Liana).
import { Size, Images, CurrentTheme } from "@ui/theme.slint";
import { Icon } from "@ui/widgets/icon.slint";
import { TextMd } from "@ui/widgets/txt.slint";
import { TimerLoader } from "@ui/widgets/loader.slint";
import { Liana } from "./liana-theme.slint";

export component LianaSlideToButton inherits Rectangle {
    border-radius: Size.sz6;
    height: Size.sz16 + (Size.sz1 * 2);

    private property <length> inner-width: self.width - Size.sz1 * 2;
    private property <length> inner-height: self.height - Size.sz1 * 2;
    private property <length> inner-element-width: thumb.width;
    private property <length> max-slide-offset: inner-width - inner-element-width;
    private property <length> slide-offset: min(max-slide-offset, max(0px, (touchArea.pressed ? touchArea.mouse-x - touchArea.pressed-x : 0)));
    private property <bool> has-activated: false;

    in property <string> id;
    in property <string> label;
    in property <string> icon: "arrow-right";
    in property <string> info-label;
    in property <string> activated-label;

    callback activated(string);

    // Nine-slice track background (neutral; reused from the shared widget).
    Image {
        width: 100%;
        height: 100%;
        source: CurrentTheme.is-dark ? Images.nine-slice("images/slide-to-bg-dark") : Images.nine-slice("images/slide-to-bg-light");

        HorizontalLayout {
            alignment: center;
            spacing: Size.sz2;

            if has-activated: VerticalLayout {
                alignment: center;
                TimerLoader { loader-color: Liana.green; }
            }

            TextMd {
                text: has-activated ? activated-label : info-label;
                color: has-activated ? Liana.green : Liana.on-surface-dim;
                horizontal-alignment: left;
                vertical-alignment: center;
            }
        }
    }

    // Target outline at the end of the track.
    target := Image {
        x: parent.width - self.width - Size.sz1;
        width: thumb.width;
        height: inner-height;
        source: CurrentTheme.is-dark ? Images.nine-slice("images/slide-to-target-dark") : Images.nine-slice("images/slide-to-target-light");
        opacity: has-activated ? 0 : 1;
    }

    // Movable green thumb.
    HorizontalLayout {
        x: Size.sz1 + slide-offset;
        y: Size.sz1;
        height: inner-height;
        width: inner-width;
        thumb := Rectangle {
            width: self.preferred-width;
            height: inner-height;
            border-radius: Size.sz6;
            background: Liana.green;
            horizontal-stretch: 0;
            opacity: has-activated ? 0 : 1;

            HorizontalLayout {
                alignment: start;
                horizontal-stretch: 0;
                spacing: Size.sz2;
                padding-left: Size.sz4;
                padding-right: Size.sz4;

                VerticalLayout {
                    alignment: center;
                    Icon {
                        name: root.icon;
                        color: Liana.on-green;
                    }
                }

                TextMd {
                    text: root.label;
                    color: Liana.on-green;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle { horizontal-stretch: 1; }
    }

    touchArea := TouchArea {
        moved() => {
            if (slide-offset >= max-slide-offset && !root.has-activated) {
                root.has-activated = true;
                root.activated(id);
            }
        }
    }
}

// Liana-branded variants of the KeyOS widgets. Geometry matches the native
// Button/cards (radius Size.sz6, height Size.sz15); only the colors change.
import { Size } from "compat/theme.slint";
import { TextLg } from "compat/widgets.slint";
import { Liana } from "./liana-theme.slint";

// Primary = solid Liana green with black label. Secondary = green outline.
export component LianaButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: true;
    in property <bool> destructive: false;  // red, for irreversible actions
    in property <bool> enabled: true;

    // Accent: red when destructive, otherwise Liana green.
    property <brush> accent: destructive ? Liana.recovery : Liana.green;
    callback clicked();

    height: Size.sz15;
    border-radius: Size.sz6;
    clip: true;
    background: primary
        ? (ta.pressed ? Liana.green-dim : root.accent)
        : #00000000;
    border-width: primary ? 0px : 2px;
    border-color: root.accent;
    opacity: enabled ? 1.0 : 0.4;

    HorizontalLayout {
        alignment: center;
        padding-left: Size.sz6;
        padding-right: Size.sz6;
        TextLg {
            text: root.label;
            bold: true;
            vertical-alignment: center;
            horizontal-alignment: center;
            color: root.primary ? Liana.on-green : root.accent;
        }
    }

    ta := TouchArea {
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

// Card with a left accent stripe hosting arbitrary children. Accent + fill
// signal intent: green = normal/destination, red = recovery, grey = change.
export component LianaCard inherits Rectangle {
    in property <bool> recovery: false;
    in property <bool> change: false;
    border-radius: Size.sz4;
    clip: true;
    background: recovery ? Liana.surface-recovery
        : (change ? Liana.surface-change : Liana.surface);

    HorizontalLayout {
        Rectangle {
            width: 4px;
            background: root.recovery ? Liana.recovery
                : (root.change ? Liana.change : Liana.green);
        }
        @children
    }
}

// A small green brand dot for the header.
export component LianaDot inherits Rectangle {
    width: Size.sz3;
    height: Size.sz3;
    border-radius: self.width / 2;
    background: Liana.green;
}
